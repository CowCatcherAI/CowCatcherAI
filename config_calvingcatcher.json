                ],
                "interval": 0.2,
                "frame_retention": 30
            },
            "yolo": {
                "model": "https://github.com/CowCatcherAI/CowCatcherAI/releases/download/model-V16/calvingcatcherV5.1y11s.pt",
                "confidence": {
