{
    "$schema": "https://raw.githubusercontent.com/ESchouten/ai-detector/winml-ep/config/config.schema.json",
    "detectors": [
        {
            "detection": {
                "source": [
                    "rtsp://<camera_1>",
                    "rtsp://<camera_2>"
                ],
                "interval": 0.2,
                "frame_retention": 60
            },
            "yolo": {
                "model": "https://github.com/CowCatcherAI/CowCatcherAI/releases/download/model-V16/cowcatcherV15.pt",
                "confidence": {
                    "mounting": 0.88
                },
                "frames_min": 5,
                "timeout": 5,
                "imgsz": 640,
                "strategy": "LATEST"
            },
            "exporters": {
                "disk": {
                    "directory": "mounting"
                },
                "telegram": {
                    "token": "<telegram_bot_token>",
                    "chat": "<telegram_chat_id>",
                    "alert_every": 5,
                    "export_rejected": true,
                    "include_plot": true,
                    "include_crop": false,
                    "include_video": true
                }
            }
        },
        {
            "detection": {
                "source": [
                    "rtsp://<camera_1>",
                    "rtsp://<camera_2>"
                ],
                "interval": 0.2,
                "frame_retention": 30
            },
            "yolo": {
                "model": "https://github.com/CowCatcherAI/CowCatcherAI/releases/download/model-V16/calvingcatcherV5.1y11s.pt",
                "confidence": {
                    "waterbag": 0.8,
                    "legs": 0.8,
                    "head": 0.8,
                    "body": 0.8,
                    "calf": 0.8
                },
                "cooldown": {
                    "calf": 900,
                    "waterbag": 900,
                    "legs": 900,
                    "head": 900,
                    "body": 900
                },
                "frames_min": 4,
                "timeout": 30,
                "imgsz": 640,
                "strategy": "LATEST"
            },
            "exporters": {
                "disk": {
                    "strategy": "ALL",                    
                    "directory": "dry_cows"
                },
                "telegram": {
                    "token": "<telegram_bot_token>",
                    "chat": "<telegram_chat_id>",
                    "alert_every": 5,
                    "export_rejected": true,
                    "include_plot": true,
                    "include_crop": false,
                    "include_video": true,
                    "confidence": {
                        "waterbag": 0.85,
                        "legs": 0.85,
                        "head": 0.85,
                        "body": 0.85,
                        "calf": 0.9
                    }
                }
            }
        },
        {
